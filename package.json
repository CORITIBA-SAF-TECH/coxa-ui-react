    "type": "git",
    "url": "git+https://github.com/CORITIBA-SAF-TECH/coxa-ui-react.git"
  },
  "bugs": {
    "url": "https://github.com/CORITIBA-SAF-TECH/coxa-ui-react/issues"
  },
